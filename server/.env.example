PORT=3000

# URL du frontend (origine autorisée par CORS et cible de redirection après login OAuth).
FRONTEND_URL=http://localhost:5173

# Base de données MySQL (valeurs alignées sur docker-compose.yml).
DB_HOST=localhost
DB_PORT=3306
DB_USER=emf
DB_PASSWORD=emf123
DB_NAME=codementor

# Secret de signature du cookie de session (chaîne aléatoire quelconque).
SESSION_SECRET=remplacer-par-une-chaine-aleatoire

# Clé de chiffrement du token OAuth (AES-256-GCM) : 64 caractères hexadécimaux.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=

# OAuth App GitHub (à créer sur https://github.com/settings/developers).
# GITHUB_CALLBACK_URL doit correspondre exactement à l'URL de callback enregistrée sur GitHub.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/codementor/api/auth/callback

# OpenRouter : clé API (https://openrouter.ai/keys) et modèle LLM utilisé.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash

# Raisonnement du LLM : "true" laisse le modèle raisonner librement (par défaut du modèle),
# toute autre valeur (ou vide) force un effort minimal pour réduire le coût des tokens.
AI_THINKING=false

# Concurrence de la file d'analyse : analyses traitées en parallèle (défaut 1)
# et fichiers analysés en parallèle par analyse (défaut 5).
ANALYSIS_CONCURRENCY=1
FILE_CONCURRENCY=5
